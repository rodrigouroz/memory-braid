{
  "id": "memory-braid",
  "name": "Memory Braid",
  "description": "Hybrid memory plugin that augments local core/QMD memory with Mem0 capture and recall.",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "mem0": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "mode": { "type": "string", "enum": ["cloud", "oss"], "default": "cloud" },
          "apiKey": { "type": "string" },
          "host": { "type": "string" },
          "organizationId": { "type": "string" },
          "projectId": { "type": "string" },
          "ossConfig": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      },
      "recall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxResults": { "type": "integer", "minimum": 1, "maximum": 50, "default": 8 },
          "injectTopK": { "type": "integer", "minimum": 1, "maximum": 20, "default": 5 },
          "user": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "injectTopK": { "type": "integer", "minimum": 1, "maximum": 20, "default": 5 }
            }
          },
          "agent": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "injectTopK": { "type": "integer", "minimum": 1, "maximum": 20, "default": 2 },
              "minScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.78 },
              "onlyPlanning": { "type": "boolean", "default": true }
            }
          },
          "merge": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "strategy": { "type": "string", "enum": ["rrf"], "default": "rrf" },
              "rrfK": { "type": "integer", "minimum": 1, "maximum": 500, "default": 60 },
              "localWeight": { "type": "number", "minimum": 0, "maximum": 5, "default": 1 },
              "mem0Weight": { "type": "number", "minimum": 0, "maximum": 5, "default": 1 }
            }
          }
        }
      },
      "capture": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "mode": {
            "type": "string",
            "enum": ["local", "hybrid", "ml"],
            "default": "local"
          },
          "includeAssistant": { "type": "boolean", "default": false },
          "maxItemsPerRun": { "type": "integer", "minimum": 1, "maximum": 50, "default": 6 },
          "selection": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "minPreferenceDecisionScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.45 },
              "minFactScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.52 },
              "minTaskScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.72 },
              "minOtherScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.82 },
              "minProceduralScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.58 }
            }
          },
          "assistant": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "autoCapture": { "type": "boolean", "default": false },
              "explicitTool": { "type": "boolean", "default": true },
              "maxItemsPerRun": { "type": "integer", "minimum": 1, "maximum": 10, "default": 2 },
              "minUtilityScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.8 },
              "minNoveltyScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.85 },
              "maxWritesPerSessionWindow": { "type": "integer", "minimum": 1, "maximum": 20, "default": 3 },
              "cooldownMinutes": { "type": "integer", "minimum": 0, "maximum": 240, "default": 5 }
            }
          },
          "ml": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "provider": { "type": "string", "enum": ["openai", "anthropic", "gemini"] },
              "model": { "type": "string" },
              "timeoutMs": { "type": "integer", "minimum": 250, "maximum": 30000, "default": 2500 }
            }
          }
        }
      },
      "entityExtraction": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "provider": {
            "type": "string",
            "enum": ["multilingual_ner", "openai"],
            "default": "multilingual_ner"
          },
          "model": {
            "type": "string",
            "default": "Xenova/bert-base-multilingual-cased-ner-hrl"
          },
          "timeoutMs": { "type": "integer", "minimum": 250, "maximum": 30000, "default": 2500 },
          "minScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.65 },
          "maxEntitiesPerMemory": { "type": "integer", "minimum": 1, "maximum": 50, "default": 8 },
          "startup": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "downloadOnStartup": { "type": "boolean", "default": true },
              "warmupText": {
                "type": "string",
                "default": "John works at Acme in Berlin."
              }
            }
          }
        }
      },
      "dedupe": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "lexical": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "minJaccard": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.3 }
            }
          },
          "semantic": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "minScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.92 }
            }
          }
        }
      },
      "timeDecay": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false }
        }
      },
      "lifecycle": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "captureTtlDays": { "type": "integer", "minimum": 1, "maximum": 3650, "default": 90 },
          "cleanupIntervalMinutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10080,
            "default": 360
          },
          "reinforceOnRecall": { "type": "boolean", "default": true }
        }
      },
      "consolidation": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "startupRun": { "type": "boolean", "default": true },
          "intervalMinutes": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10080,
            "default": 360
          },
          "opportunisticNewMemoryThreshold": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 5
          },
          "opportunisticMinMinutesSinceLastRun": {
            "type": "integer",
            "minimum": 1,
            "maximum": 1440,
            "default": 30
          },
          "minSupportCount": { "type": "integer", "minimum": 1, "maximum": 50, "default": 2 },
          "minRecallCount": { "type": "integer", "minimum": 1, "maximum": 100, "default": 2 },
          "minSelectionScore": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.56 },
          "semanticMaxSourceIds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 20
          },
          "timeQueryParsing": { "type": "boolean", "default": true }
        }
      },
      "debug": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "includePayloads": { "type": "boolean", "default": false },
          "maxSnippetChars": { "type": "integer", "minimum": 40, "maximum": 8000, "default": 500 },
          "logSamplingRate": { "type": "number", "minimum": 0, "maximum": 1, "default": 1 }
        }
      }
    }
  }
}
